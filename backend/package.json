{
  "name": "dailying-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for the dailying morning-ritual app: assembles a calm daily briefing from Google Calendar + Gmail + news, summarized by Claude.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "worker": "tsx --env-file=.env src/jobs/worker.ts",
    "worker:prod": "node --env-file=.env dist/jobs/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "undici": "^7.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
