# ── Server ──────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
# Comma-separated origins allowed to call the API (the iOS app uses none of
# these in production, but local web tooling / the simulator dev proxy might).
CORS_ORIGINS=http://localhost:3000

# ── Datastores ──────────────────────────────────────────────────────────
# Two run modes (see README → "Running it"):
#
#   A) Dev on the Mac, datastores on the homeserver (default workflow):
#      point these at the homeserver over Tailscale. `homelab` resolves to its
#      Tailscale IP via MagicDNS, and the stores are bound to that IP only.
#        DATABASE_URL=postgresql://dailying:dailying@homelab:5432/dailying?schema=public
#        REDIS_URL=redis://homelab:6379
#
#   B) Full stack in containers on the homeserver (docker-compose.prod.yml):
#      the api/worker containers reach the stores by service name. The prod
#      overlay sets these for you, so you can leave the dev values here.
#
# Postgres connection string used by Prisma.
DATABASE_URL=postgresql://dailying:dailying@homelab:5432/dailying?schema=public
# Redis URL used by BullMQ (briefing queue) and refresh-token storage.
REDIS_URL=redis://homelab:6379

# Host interface the datastore (and prod API) ports bind to. On the homeserver
# this is its Tailscale IP so the stack is reachable from the tailnet (dev Mac,
# phone) but not the LAN/internet. Leave unset for a private localhost bind.
BIND_IP=

# ── Auth / sessions ─────────────────────────────────────────────────────
# Secret used to sign the app's own session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
# Access token lifetime (the app refreshes silently before this expires).
JWT_ACCESS_TTL=15m
# Refresh token lifetime.
REFRESH_TTL_DAYS=30

# ── Google OAuth (Calendar + Gmail) ─────────────────────────────────────
# TODO(liam): create an OAuth 2.0 Client ID (type: iOS or Web) in Google Cloud
# Console, enable the Calendar API and Gmail API, and paste the values here.
# Scopes requested: calendar.readonly, gmail.readonly, userinfo.email/profile.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Where Google redirects after consent. For the iOS app this is typically a
# custom scheme or a backend-hosted callback. Must match the Console config.
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ── Sign in with Apple (optional second identity provider) ──────────────
# TODO(liam): fill these from the Apple Developer portal if you wire Apple auth.
# Leaving them blank disables the Apple route; Google alone is enough to ship.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── Anthropic (Claude summarization pipeline) ───────────────────────────
# TODO(liam): create a key at https://console.anthropic.com/ and paste it.
ANTHROPIC_API_KEY=
# Model used to summarize the briefing. Opus 4.8 is the current default.
ANTHROPIC_MODEL=claude-opus-4-8

# ── News provider ───────────────────────────────────────────────────────
# TODO(liam): pick a news API and paste a key. The default adapter targets
# NewsAPI.org (https://newsapi.org/). Swap NEWS_PROVIDER to change adapters.
NEWS_PROVIDER=newsapi
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

# ── Briefing job schedule ───────────────────────────────────────────────
# Cron for the nightly/early-morning generation sweep (server local time).
# Default: every day at 04:30. Users still get an on-demand fresh fetch if
# they open the app before the sweep has run for their timezone.
BRIEFING_CRON=30 4 * * *
# Hard cap on cards per briefing (the ritual is bounded). Matches the app.
MAX_CARDS=5
